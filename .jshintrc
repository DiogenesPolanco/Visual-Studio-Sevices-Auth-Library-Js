{
  "bitwise": true,
  "camelcase": false,
  "curly": true,
  "eqeqeq": false,
  "forin": true,
  "freeze": true,
  "immed": false,
  "indent": 2,
  "latedef": false,
  "maxparams": false,
  "maxdepth": false,
  "maxstatements": false,
  "maxcomplexity": false,
  "multistr" : true,
  "newcap": true,
  "noarg": true,
  "node": false,
  "noempty": true,
  "nonew": false,
  "plusplus": false,
  "quotmark": "single",
  "regexp": true,
  "sub": true,
  "strict": false,
  "trailing": false,
  "undef": false,
  "unused": false,
  "browser": true,
  "globals": {
    "window": true,
    "document": true,
    "navigator": true,
    "setTimeout": true,
    "setInterval": true,
    "clearTimeout": true,
    "clearInterval": true,
    "localStorage": true,
    "sessionStorage": true,
    "Promise": true,
    "XMLHttpRequest": true,
    "atob": true,
    "define": true,
    "angular": true
  }
}
